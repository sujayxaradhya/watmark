{
  "name": "watmark",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:web": "bun run --filter web dev",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@watmark/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@watmark/config": "workspace:*",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "catalog:",
    "ultracite": "7.3.2"
  },
  "packageManager": "bun@1.2.18"
}
